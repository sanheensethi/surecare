---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, cover, coverAlt, tags } = post.data;

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const canonical = new URL(`/blog/${post.id}`, Astro.site).href;
const ogImage = cover
  ? cover.startsWith('http')
    ? cover
    : new URL(cover, Astro.site).href
  : undefined;

// BlogPosting structured data — gives each article rich-result eligibility.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Organization', name: author },
  publisher: {
    '@type': 'MedicalClinic',
    name: 'Surecare Clinic, Yelahanka',
    url: Astro.site?.href,
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  ...(ogImage ? { image: ogImage } : {}),
  ...(tags.length ? { keywords: tags.join(', ') } : {}),
};
---
<BaseLayout
  title={`${title} | Surecare Clinic, Yelahanka`}
  description={description}
  image={cover}
  type="article"
  jsonLd={jsonLd}
>
  <article class="section">
    <div class="container post">
      <nav class="post__breadcrumb" aria-label="Breadcrumb">
        <a href={`${base}/`}>Home</a> <span aria-hidden="true">/</span>
        <a href={`${base}/blog`}>Blog</a> <span aria-hidden="true">/</span>
        <span>{title}</span>
      </nav>

      <header class="post__header">
        {tags.length > 0 && <span class="eyebrow">{tags[0]}</span>}
        <h1 class="post__title">{title}</h1>
        <p class="post__meta">
          By {author} &middot; <time datetime={pubDate.toISOString()}>{fmtDate(pubDate)}</time>
          {updatedDate && <> &middot; Updated {fmtDate(updatedDate)}</>}
        </p>
      </header>

      {cover && (
        <img class="post__cover" src={cover} alt={coverAlt} loading="eager" width="1200" height="630" />
      )}

      <div class="prose">
        <slot />
      </div>

      <div class="post__cta">
        <p>Have a health concern you'd like to discuss with our specialists?</p>
        <div class="hero__actions">
          <a href={`${base}/appointment`} class="btn btn-primary">Book an Appointment</a>
          <a href="https://wa.me/919966351994?text=Hello%20Surecare%20Clinic" target="_blank" rel="noopener" class="btn btn-outline">Chat on WhatsApp</a>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post { max-width: 760px; }

  .post__breadcrumb {
    font-size: 0.85rem;
    color: var(--clr-text-muted);
    margin-bottom: 1.5rem;
  }
  .post__breadcrumb a { color: var(--clr-primary); text-decoration: none; }
  .post__breadcrumb a:hover { text-decoration: underline; }
  .post__breadcrumb span { margin: 0 0.35rem; }

  .post__header { margin-bottom: 1.75rem; }
  .post__title {
    font-family: var(--font-head);
    font-size: clamp(1.9rem, 4vw, 2.6rem);
    line-height: 1.15;
    color: var(--clr-text);
    margin: 0.5rem 0 0.75rem;
  }
  .post__meta { color: var(--clr-text-muted); font-size: 0.95rem; margin: 0; }

  .post__cover {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    margin-bottom: 2rem;
  }

  /* Readable long-form article body, built on the site's design tokens. */
  .prose { color: var(--clr-text); font-size: 1.075rem; line-height: 1.75; }
  .prose :global(h2) {
    font-family: var(--font-head);
    font-size: 1.6rem;
    line-height: 1.25;
    margin: 2.25rem 0 0.85rem;
    color: var(--clr-text);
  }
  .prose :global(h3) {
    font-family: var(--font-head);
    font-size: 1.25rem;
    margin: 1.75rem 0 0.6rem;
    color: var(--clr-text);
  }
  .prose :global(p) { margin: 0 0 1.15rem; }
  .prose :global(a) { color: var(--clr-primary); text-decoration: underline; }
  .prose :global(ul),
  .prose :global(ol) { margin: 0 0 1.15rem 1.25rem; padding-left: 0.75rem; }
  .prose :global(li) { margin-bottom: 0.5rem; }
  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin: 1.5rem 0;
  }
  .prose :global(blockquote) {
    border-left: 4px solid var(--clr-primary);
    background: var(--clr-bg-alt);
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-sm);
    color: var(--clr-text-muted);
  }
  .prose :global(strong) { color: var(--clr-text); }
  .prose :global(hr) { border: none; border-top: 1px solid var(--clr-border); margin: 2rem 0; }

  .post__cta {
    margin-top: 2.5rem;
    padding: 1.75rem;
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-lg);
    background: var(--clr-bg-alt);
    text-align: center;
  }
  .post__cta p { margin: 0 0 1rem; font-weight: 600; color: var(--clr-text); }
  .post__cta .hero__actions { justify-content: center; }
</style>
