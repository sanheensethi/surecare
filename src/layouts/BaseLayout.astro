        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>Mon&ndash;Sat 7:00&nbsp;AM&ndash;9:00&nbsp;PM &middot; Sun 7:00&nbsp;AM&ndash;1:00&nbsp;PM</span>
      </li>
    </ul>
    <div class="utility-bar__socials">
      <a href="https://www.instagram.com/surecare.clinic.yelahanka" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg></a>
    </div>
  </div>
</div>

<!-- ============ NAVBAR (sticky) ============ -->
<header class="navbar" data-navbar>
  <nav class="container navbar__inner" aria-label="Primary">
    <a href={r('/')} class="brand brand--logo" aria-label="Surecare Clinic — We care for you">
      <img class="brand__mark-img" src={r('/images/logo-mark.png')} alt="" width="64" height="64" />
      <span class="brand__words">
        <span class="brand__name">SURECARE CLINIC</span>
        <span class="brand__tag">We care for you</span>
      </span>
    </a>

    <ul class="nav-menu" data-nav-menu id="primary-menu">
      {navItems.map((item) => (
        <li>
          <a
            class:list={['nav-menu__link', { 'is-active': isActive(item.href) }]}
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >{item.label}</a>
        </li>
      ))}
      <li class="nav-menu__cta"><a class="btn btn-primary" href={r('/appointment')}>Book Appointment</a></li>
    </ul>

    <div class="nav-actions">
      <a href={r('/appointment')} class="btn btn-primary btn-sm">Book Appointment</a>
      <button class="nav-toggle" type="button" data-nav-toggle aria-label="Toggle menu" aria-expanded="false" aria-controls="primary-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
</header>
<div class="nav-backdrop" data-nav-backdrop></div>

<slot />

