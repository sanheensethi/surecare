---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'Surecare Clinic Health Blog',
  description:
    'Health tips, condition guides and clinic updates from Surecare Clinic, Yelahanka — covering urology, general medicine, diagnostics and family wellness.',
  url: new URL('/blog', Astro.site).href,
};
---
<BaseLayout
  title="Health Blog | Surecare Clinic, Yelahanka"
  description="Health tips, condition guides and wellness advice from the specialists at Surecare Clinic, Yelahanka — urology, general medicine, diagnostics and more."
  jsonLd={jsonLd}
>
  <section class="section">
    <div class="container">
      <div class="section-head fade-up">
        <span class="eyebrow">Surecare Health Blog</span>
        <h1 class="section-title">Health Tips & Clinic Updates</h1>
        <p class="section-subtitle">Practical, doctor-reviewed guidance on staying healthy — from urology and kidney care to everyday family wellness.</p>
      </div>

      {posts.length === 0 ? (
        <p style="text-align:center;color:var(--clr-text-muted);">New articles are coming soon. Check back shortly.</p>
      ) : (
        <div class="grid grid--3">
          {posts.map((post) => (
            <article class="card fade-up" style="display:flex;flex-direction:column;overflow:hidden;padding:0;">
              {post.data.cover && (
                <a href={`/blog/${post.id}`} aria-label={post.data.title}>
                  <img
                    src={post.data.cover}
                    alt={post.data.coverAlt}
                    loading="lazy"
                    width="800"
                    height="450"
                    style="width:100%;aspect-ratio:16/9;object-fit:cover;border-radius:0;"
                  />
                </a>
              )}
              <div style="padding:1.5rem;display:flex;flex-direction:column;flex:1;">
                {post.data.tags[0] && <span class="eyebrow">{post.data.tags[0]}</span>}
                <h2 class="service-card__title" style="margin:0.35rem 0 0.5rem;">
                  <a href={`/blog/${post.id}`} style="color:inherit;text-decoration:none;">{post.data.title}</a>
                </h2>
                <p class="service-card__text" style="flex:1;">{post.data.description}</p>
                <p style="color:var(--clr-text-muted);font-size:0.85rem;margin:0.75rem 0 0;">
                  <time datetime={post.data.pubDate.toISOString()}>{fmtDate(post.data.pubDate)}</time>
                </p>
                <a href={`/blog/${post.id}`} class="service-card__link" style="margin-top:0.75rem;">Read more
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
