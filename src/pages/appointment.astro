---
import BaseLayout from '../layouts/BaseLayout.astro';
import body from '../partials/appointment.html?raw';
---
<BaseLayout
  title="Book an Appointment | Surecare Clinic, Yelahanka"
  description="Book an appointment at Surecare Clinic, Yelahanka. Choose your department, preferred date and time, and confirm instantly on WhatsApp. Urology with Dr. Ashwin Giridhar, plus pharmacy, diagnostics & home collection."
  image="https://images.unsplash.com/photo-1538108149393-fbbd81895907?auto=format&fit=crop&w=1200&q=80"
>
  <Fragment set:html={body} />

  <!-- Page-specific styles (originally inline in appointment.html's <head>).
       Must be is:global so they reach the set:html body markup. -->
  <style is:global>
    .appointment-layout {
      display: grid;
      grid-template-columns: 1.6fr 1fr;
      gap: 2.5rem;
      align-items: start;
    }
    @media (max-width: 992px) {
      .appointment-layout { grid-template-columns: 1fr; }
    }

    /* Sidebar cards stack */
    .appt-sidebar { display: flex; flex-direction: column; gap: 1.5rem; }

    .appt-card {
      background: var(--clr-white);
      border: 1px solid var(--clr-border);
      border-radius: var(--radius-lg);
      padding: 1.75rem;
      box-shadow: var(--shadow-sm);
    }
    .appt-card__title {
      font-size: 1.15rem;
      margin: 0 0 1rem;
      display: flex;
      align-items: center;
      gap: .6rem;
    }
    .appt-card__title svg { width: 1.3em; height: 1.3em; color: var(--clr-primary); flex: none; }

    .appt-card--highlight {
      background: var(--grad-primary);
      color: var(--clr-white);
      border: none;
      box-shadow: var(--shadow-green);
    }
    .appt-card--highlight .appt-card__title,
    .appt-card--highlight .appt-card__title svg { color: var(--clr-white); }
    .appt-card--highlight p { color: rgba(255,255,255,.92); margin: 0 0 .35rem; }
    .appt-card--highlight strong { color: var(--clr-white); }

    /* Hours mini-list */
    .hours-list { list-style: none; margin: 0; padding: 0; }
    .hours-list li {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding: .55rem 0;
      border-bottom: 1px solid var(--clr-border);
      font-size: .95rem;
    }
    .hours-list li:last-child { border-bottom: none; }
    .hours-list .hours-list__day { color: var(--clr-text-muted); font-weight: 500; }
    .hours-list .hours-list__time { font-weight: 600; color: var(--clr-text); }

    .appt-card__actions { display: flex; flex-direction: column; gap: .75rem; margin-top: .25rem; }

    .appt-note {
      font-size: .9rem;
      color: var(--clr-text-muted);
      margin: 1rem 0 0;
    }

    /* Reminder card */
    .reminder-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .85rem; }
    .reminder-list li { display: flex; gap: .7rem; align-items: flex-start; font-size: .95rem; line-height: 1.5; }
    .reminder-list svg { width: 1.25em; height: 1.25em; color: var(--clr-primary); flex: none; margin-top: .12em; }

    /* Success / status note */
    .form-status {
      display: none;
      align-items: center;
      gap: .7rem;
      margin-bottom: 1.5rem;
      padding: 1rem 1.15rem;
      border-radius: var(--radius-md);
      background: var(--clr-mint);
      border: 1px solid var(--clr-border-green);
      color: var(--clr-primary-dark);
      font-weight: 600;
      font-size: .97rem;
    }
    .form-status.is-visible { display: flex; }
    .form-status svg { width: 1.4em; height: 1.4em; flex: none; color: var(--clr-primary); }
    .form-status--error {
      background: #fef2f2;
      border-color: #fecaca;
      color: #b91c1c;
    }
    .form-status--error svg { color: #dc2626; }

    /* How it works steps */
    .steps {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      counter-reset: step;
    }
    @media (max-width: 768px) { .steps { grid-template-columns: 1fr; } }
    .step {
      position: relative;
      background: var(--clr-white);
      border: 1px solid var(--clr-border);
      border-radius: var(--radius-lg);
      padding: 2rem 1.75rem;
      text-align: center;
      box-shadow: var(--shadow-sm);
    }
    .step__num {
      width: 56px; height: 56px;
      margin: 0 auto 1.1rem;
      display: flex; align-items: center; justify-content: center;
      border-radius: var(--radius-circle);
      background: var(--grad-primary);
      color: var(--clr-white);
      font-family: "Plus Jakarta Sans", sans-serif;
      font-weight: 800;
      font-size: 1.4rem;
      box-shadow: var(--shadow-green);
    }
    .step__title { font-size: 1.15rem; margin: 0 0 .5rem; }
    .step__text { color: var(--clr-text-muted); margin: 0; font-size: .95rem; line-height: 1.55; }
  </style>

  <script is:inline slot="end">
(function () {
    // Paste Google Apps Script Web App URL here to sync bookings to Google Sheets
    const SHEETS_WEBHOOK_URL = "";

    const WHATSAPP_NUMBER = "919966351994";

    const form = document.getElementById("appointmentForm");
    const statusEl = document.getElementById("formStatus");
    const statusText = document.getElementById("formStatusText");
    const dateInput = document.getElementById("date");

    // Set min date = today (no past dates)
    if (dateInput) {
      const today = new Date();
      const yyyy = today.getFullYear();
      const mm = String(today.getMonth() + 1).padStart(2, "0");
      const dd = String(today.getDate()).padStart(2, "0");
      dateInput.min = yyyy + "-" + mm + "-" + dd;
    }

    function showStatus(message, isError) {
      if (!statusEl) return;
      statusText.innerHTML = message;
      statusEl.classList.add("is-visible");
      statusEl.classList.toggle("form-status--error", !!isError);
      statusEl.scrollIntoView({ behavior: "smooth", block: "center" });
    }

    if (!form) return;

    form.addEventListener("submit", function (e) {
      e.preventDefault();

      // Native + custom validation
      if (!form.checkValidity()) {
        const phone = document.getElementById("phone");
        if (phone && !phone.checkValidity()) {
          showStatus("Please enter a valid 10-digit mobile number starting with 6–9.", true);
        } else {
          showStatus("Please fill in all required fields (name, phone &amp; department).", true);
        }
        form.reportValidity();
        return;
      }

      const data = {
        fullName: form.fullName.value.trim(),
        phone: form.phone.value.trim(),
        department: form.department.value,
        date: form.date.value || "Not specified",
        time: form.time.value || "Not specified",
        message: form.message.value.trim() || "—",
        submittedAt: new Date().toISOString()
      };

      // (1) Optionally sync to Google Sheets via Apps Script webhook
      if (SHEETS_WEBHOOK_URL) {
        try {
          fetch(SHEETS_WEBHOOK_URL, {
            method: "POST",
            mode: "no-cors",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data)
          }).catch(function () { /* non-blocking */ });
        } catch (err) { /* non-blocking */ }
      }

      // (2) Always open WhatsApp with a pre-filled booking message
      const lines = [
        "*New Appointment Request — Surecare Clinic, Yelahanka*",
        "",
        "Name: " + data.fullName,
        "Phone: " + data.phone,
        "Department/Service: " + data.department,
        "Preferred Date: " + data.date,
        "Preferred Time: " + data.time,
        "Message: " + data.message
      ];
      const waText = encodeURIComponent(lines.join("\n"));
      const waUrl = "https://wa.me/" + WHATSAPP_NUMBER + "?text=" + waText;

      showStatus("Opening WhatsApp to confirm your booking&hellip;", false);

      window.open(waUrl, "_blank", "noopener");
    });
  })();
  </script>
</BaseLayout>
