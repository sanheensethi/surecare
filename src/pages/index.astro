---
import BaseLayout from '../layouts/BaseLayout.astro';
import body from '../partials/index.html?raw';

// MedicalClinic structured data — drives Google's local/medical rich results.
// `url` resolves from the `site` value in astro.config.mjs.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MedicalClinic',
  name: 'Surecare Clinic, Yelahanka',
  description:
    'Multispeciality clinic with in-house pharmacy and diagnostic lab in Yelahanka, Bengaluru. Complete care under one roof — consultations, pharmacy with home delivery and diagnostics with home sample collection.',
  url: Astro.site?.href,
  telephone: '+91-99889-96188',
  priceRange: '₹₹',
  address: {
    '@type': 'PostalAddress',
    streetAddress:
      '1216, 8th B Cross Rd, Opposite Indira Canteen, Yelahanka Satellite Town, Yelahanka New Town',
    addressLocality: 'Bengaluru',
    addressRegion: 'Karnataka',
    postalCode: '560064',
    addressCountry: 'IN',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 13.1007, longitude: 77.5963 },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      opens: '07:00',
      closes: '21:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Sunday',
      opens: '07:00',
      closes: '13:00',
    },
  ],
  medicalSpecialty: [
    'Urology', 'Neurology', 'Nephrology', 'PrimaryCare', 'Pediatric',
    'Gynecologic', 'Dermatology', 'Orthopedic', 'Cardiovascular',
    'Diabetic', 'Pulmonary', 'Otolaryngologic',
  ],
  availableService: [
    { '@type': 'MedicalProcedure', name: 'Kidney Stone Treatment (Laser / Endoscopic)' },
    { '@type': 'MedicalProcedure', name: 'Renal Transplantation' },
    { '@type': 'MedicalProcedure', name: 'Uro-Oncology' },
    { '@type': 'MedicalTest', name: 'Blood & Urine Diagnostics with Home Sample Collection' },
  ],
};
---
<BaseLayout
  title="Surecare Clinic Yelahanka — Multispeciality Clinic & Lab"
  description="Complete care under one roof in Yelahanka, Bengaluru — expert consultations, an in-house pharmacy with home delivery and on-site lab diagnostics."
  image="https://images.unsplash.com/photo-1538108149393-fbbd81895907?auto=format&fit=crop&w=1200&q=80"
  jsonLd={jsonLd}
>
  <Fragment set:html={body} />
</BaseLayout>
