---
import BaseLayout from '../layouts/BaseLayout.astro';
import body from '../partials/index.html?raw';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MedicalClinic',
  name: 'Surecare Clinic, Yelahanka',
  description:
    'Multispeciality clinic in Yelahanka, Bengaluru — expert uro-oncologist Dr. Ashwin Giridhar. Treatment for kidney cancer, bladder cancer, prostate cancer, kidney stones, UTI, andrology and more. In-house pharmacy and Apollo diagnostics lab with home sample collection.',
  url: Astro.site?.href,
  telephone: '+91-99889-96188',
  priceRange: '₹₹',
  address: {
    '@type': 'PostalAddress',
    streetAddress:
      '1216, 8th B Cross Rd, Opposite Indira Canteen, Yelahanka Satellite Town, Yelahanka New Town',
    addressLocality: 'Bengaluru',
    addressRegion: 'Karnataka',
    postalCode: '560064',
    addressCountry: 'IN',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 13.1007, longitude: 77.5963 },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      opens: '07:00',
      closes: '21:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Sunday',
      opens: '07:00',
      closes: '13:00',
    },
  ],
  medicalSpecialty: [
    'Urology', 'Uro-Oncology', 'Neurology', 'Nephrology', 'Oncology',
    'Transplantation', 'GeneralSurgery',
  ],
  availableService: [
    { '@type': 'MedicalProcedure', name: 'Kidney Cancer Treatment (Uro-Oncology)' },
    { '@type': 'MedicalProcedure', name: 'Bladder Cancer Treatment' },
    { '@type': 'MedicalProcedure', name: 'Prostate Cancer Treatment' },
    { '@type': 'MedicalProcedure', name: 'Penile Cancer Treatment' },
    { '@type': 'MedicalProcedure', name: 'Adrenal Cancer / Tumour' },
    { '@type': 'MedicalProcedure', name: 'Urothelial Cancer Treatment' },
    { '@type': 'MedicalProcedure', name: 'Testicular Cancer Treatment' },
    { '@type': 'MedicalProcedure', name: 'RPLND (Retroperitoneal Lymph Node Dissection)' },
    { '@type': 'MedicalProcedure', name: 'IVC Thrombectomy' },
    { '@type': 'MedicalProcedure', name: 'Kidney Stone Treatment (Laser / Endoscopic)' },
    { '@type': 'MedicalProcedure', name: 'Bladder Stone Treatment' },
    { '@type': 'MedicalProcedure', name: 'Kidney Transplant Surgery' },
    { '@type': 'MedicalProcedure', name: 'UTI Treatment' },
    { '@type': 'MedicalProcedure', name: 'Andrology' },
    { '@type': 'MedicalTest', name: 'Blood & Urine Diagnostics with Home Sample Collection' },
  ],
};
---
<BaseLayout
  title="Best Urologist & Uro-Oncologist in Yelahanka, Bengaluru | Surecare Clinic"
  description="Surecare Clinic, Yelahanka — Dr. Ashwin Giridhar, APJ Abdul Kalam awardee Uro-Oncologist. Expert treatment for kidney cancer, bladder cancer, prostate cancer, kidney stones & UTI. In-house pharmacy & Apollo diagnostics. Open 7 days."
  image="https://images.unsplash.com/photo-1538108149393-fbbd81895907?auto=format&fit=crop&w=1200&q=80"
  jsonLd={jsonLd}
>
  <Fragment set:html={body} />
</BaseLayout>
