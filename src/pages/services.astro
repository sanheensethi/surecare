---
import BaseLayout from '../layouts/BaseLayout.astro';
import body from '../partials/services.html?raw';

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Do I need an appointment to visit?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Walk-ins are welcome for general consultations during our opening hours (Mon–Sat 7 AM–9 PM, Sunday 7 AM–1 PM). For specialist consultations — especially Urology with Dr. Ashwin Giridhar, and visiting super-specialist consultants — we strongly recommend booking ahead. You can book online via our appointment page, call +91 99889 96188, or message us on WhatsApp.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I get medicines right after my consultation?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Our in-house pharmacy is located right at the clinic, so you can collect all prescribed medicines immediately after your consultation — no second trip needed. You can also enquire about medicines on WhatsApp at +91 99889 96188.',
      },
    },
    {
      '@type': 'Question',
      name: 'How fast are lab reports ready?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most routine tests — such as CBC, Lipid Profile, LFT, KFT, Thyroid and HbA1c — are typically ready the same day or by the next day. Cultures and specialised tests take longer. We always give you an expected report time when you book.',
      },
    },
    {
      '@type': 'Question',
      name: 'When is Dr. Ashwin Giridhar available?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Dr. Ashwin Giridhar, our Consultant Urologist, Transplant Surgeon & Uro-Oncologist, is available at Surecare Clinic from 6 PM–8 PM, Monday to Friday. Super-specialist consultations in other oncology and surgical specialties are by appointment — please contact us at +91 99889 96188.',
      },
    },
    {
      '@type': 'Question',
      name: 'What payment methods do you accept?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'We accept cash, credit and debit cards, and UPI / online payments — for consultations, pharmacy purchases and lab tests alike.',
      },
    },
  ],
};
---
<BaseLayout
  title="Urology, Uro-Oncology & Specialist Services in Yelahanka | Surecare Clinic"
  description="Expert urology, uro-oncology & specialist care at Surecare Clinic, Yelahanka. Treatment for kidney cancer, bladder cancer, prostate cancer, kidney stones, UTI & andrology. Apollo diagnostics lab with home sample collection & in-house pharmacy."
  image="https://images.unsplash.com/photo-1584982751601-97dcc096659c?auto=format&fit=crop&w=1200&q=80"
  jsonLd={faqJsonLd}
>
  <Fragment set:html={body} />
</BaseLayout>
