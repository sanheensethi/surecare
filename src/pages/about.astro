---
import BaseLayout from '../layouts/BaseLayout.astro';
import raw from '../partials/about.html?raw';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const body = raw.replace(/src="\/images\//g, `src="${base}/images/`);
---
<BaseLayout
  title="About | Dr. Ashwin Giridhar — Uro-Oncologist in Yelahanka | Surecare Clinic"
  description="Meet Dr. Ashwin Giridhar, APJ Abdul Kalam awardee Uro-Oncologist & Urologist at Surecare Clinic, Yelahanka. Expert in kidney cancer, bladder cancer, prostate cancer, kidney transplant, RPLND, IVC thrombectomy & all urological conditions."
  image="https://images.unsplash.com/photo-1538108149393-fbbd81895907?auto=format&fit=crop&w=1200&q=80"
>
  <Fragment set:html={body} />
</BaseLayout>
